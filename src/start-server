#!/usr/bin/env python3
import argparse
import sys
import os

from lib.helpers import setup_logger
from lib.server.dispatcher import ServerDispatcher


def main():
    parser = argparse.ArgumentParser(description='UDP File Server')

    verbosity = parser.add_mutually_exclusive_group()
    verbosity.add_argument('-v', '--verbose', action='store_true', help='Force debug messages (packet-level traces)')
    verbosity.add_argument('-q', '--quiet', action='store_true', help='Suppress debug messages; show only essential info')

    parser.add_argument('-H', '--host', type=str, default='0.0.0.0', help='Listening IP address')
    parser.add_argument('-p', '--port', type=int, default=8080, help='Listening port')
    default_storage = os.path.normpath(os.path.join(os.path.dirname(__file__), '..', 'server_storage'))
    parser.add_argument('-s', '--storage', type=str, default=default_storage, help='Destination storage directory')

    args = parser.parse_args()
    logger = setup_logger(args.verbose, args.quiet, "Server")

    try:
        os.makedirs(args.storage, exist_ok=True)
    except OSError as e:
        logger.error(f"Cannot create storage directory '{args.storage}': {e}")
        sys.exit(1)

    try:
        servidor = ServerDispatcher(args.host, args.port, args.storage, logger)
        servidor.start()
    except KeyboardInterrupt:
        logger.info("Shutting down server safely...")
    except Exception as e:
        logger.error(f"Fatal error: {e}")
        sys.exit(1)

if __name__ == '__main__':
    main()